#### **B. Implementazione in Go (libp2p)**
```go
package main

import (
	"context"
	"fmt"
	"time"

	"github.com/libp2p/go-libp2p"
	"github.com/libp2p/go-libp2p-core/host"
	"github.com/libp2p/go-libp2p-core/network"
	"github.com/libp2p/go-libp2p-core/peer"
	"github.com/libp2p/go-libp2p-core/protocol"
	"github.com/multiformats/go-multiaddr"
)

const (
	GossipProtocolID = protocol.ID("/orgon/gossip/1.0.0")
	BufferSize       = 1024 * 1024 // 1MB
	TTL              = 10
)

func main() {
	// 1. Creazione del nodo libp2p
	ctx := context.Background()
	h, err := libp2p.New(
		ctx,
		libp2p.ListenAddrStrings("/ip4/0.0.0.0/tcp/4001"),
		libp2p.EnableRelay(),
	)
	if err != nil {
		panic(err)
	}
	defer h.Close()

	fmt.Printf("Nodo libp2p avviato: %s\n", h.ID())

	// 2. Connessione ai peer di bootstrap (Pacific/Indian Cluster)
	bootstrapPeers := []string{
		"/ip4/192.168.1.100/tcp/4001/p2p/QmPeer1",
		"/ip4/192.168.1.101/tcp/4001/p2p/QmPeer2",
	}
	for _, addr := range bootstrapPeers {
		ma, err := multiaddr.NewMultiaddr(addr)
		if err != nil {
			fmt.Printf("Errore parsing indirizzo: %v\n", err)
			continue
		}
		pi, err := peer.AddrInfoFromP2PAddr(ma)
		if err != nil {
			fmt.Printf("Errore estrazione peer info: %v\n", err)
			continue
		}
		if err := h.Connect(ctx, *pi); err != nil {
			fmt.Printf("Errore connessione a %s: %v\n", pi.ID, err)
		} else {
			fmt.Printf("Connesso a bootstrap peer: %s\n", pi.ID)
		}
	}

	// 3. Avvio del protocollo gossip
	h.SetStreamHandler(GossipProtocolID, handleGossipStream)

	// 4. Invio di un messaggio di test (Orgon_Flux_Stabilizer)
	go func() {
		time.Sleep(5 * time.Second)
		sendGossipMessage(h, []byte("Orgon_Flux_Stabilizer: SYNC_OK"))
	}()

	// 5. Loop principale per ricezione messaggi
	select {}
}

func handleGossipStream(s network.Stream) {
	defer s.Close()
	buf := make([]byte, BufferSize)
	n, err := s.Read(buf)
	if err != nil {
		fmt.Printf("Errore lettura stream: %v\n", err)
		return
	}
	fmt.Printf("Messaggio ricevuto: %s\n", string(buf[:n]))
}

func sendGossipMessage(h host.Host, data []byte) {
	// Selezione casuale di un peer connesso
	peers := h.Peerstore().Peers()
	if len(peers) == 0 {
		fmt.Println("Nessun peer connesso")
		return
	}
	targetPeer := peers[0]

	// Creazione dello stream
	s, err := h.NewStream(context.Background(), targetPeer, GossipProtocolID)
	if err != nil {
		fmt.Printf("Errore creazione stream: %v\n", err)
		return
	}
	defer s.Close()

	// Invio del messaggio
	_, err = s.Write(data)
	if err != nil {
		fmt.Printf("Errore invio messaggio: %v\n", err)
	}
}
```

