#!/usr/bin/env python3
# frequency-watchdog.py
# Monitoraggio e correzione automatica 0.043 Hz

import time
import numpy as np
from sensors import FrequencySensor

TARGET_FREQ = 0.043
TOLERANCE = 0.0005  # 0.5%
CHECK_INTERVAL = 1.0

def monitor_frequency():
    sensors = FrequencySensor.get_all()
    
    while True:
        frequencies = [s.read() for s in sensors]
        avg_freq = np.mean(frequencies)
        deviation = abs(avg_freq - TARGET_FREQ) / TARGET_FREQ
        
        if deviation > TOLERANCE:
            offset = TARGET_FREQ - avg_freq
            print(f"⚠️ Drift rilevato: {deviation*100:.2f}%")
            print(f"📊 Correzione: {offset:.6f} Hz")
            
            for sensor in sensors:
                sensor.apply_offset(offset)
            
            print("✅ Ricalibrazione completata")
        else:
            print(f"✓ Frequenza OK: {avg_freq:.6f} Hz")
        
        time.sleep(CHECK_INTERVAL)

if __name__ == "__main__":
