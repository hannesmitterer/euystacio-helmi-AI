from sklearn.naive_bayes import GaussianNB

class EntropyPredictor:
    def __init__(self):
        self.model = GaussianNB()
        self.training_data = []

    def train(self, historical_data: List[Tuple[float, float]]):
        """Storico: (frequenza_dshankaes, entropia_precedente)"""
        X = np.array([x[0] for x in historical_data]).reshape(-1, 1)
        y = np.array([x[1] for x in historical_data])
        self.model.fit(X, y)

    def predict(self, dshankaes_freq: float) -> float:
        """Prevede l'entropia attesa per un dato nodo."""
        return self.model.predict([[dshankaes_freq]])[0]
