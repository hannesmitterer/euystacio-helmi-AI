"""
        for node, info in self.active_nodes.items():
            report += f"\n  {node.value.upper():<26} | "
            report += f"Pulses: {info['pulse_count']:<4} | "
            report += f"Last Sync: {info['last_resonant'][:19] if info['last_resonant'] else 'Awaiting':<19}"

        report += f"\n\n🌊 RECENT PULSE ACTIVITY (Last 3)\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n"
        for p in self.pulse_stream[-3:]:
