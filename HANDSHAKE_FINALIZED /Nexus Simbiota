            report += f"{p.from_node.value} → "
            report += f"{p.to_node.value if p.to_node else 'GLOBAL_MESH'}\n    "
            report += f"Data: {p.content[:65]}..." if len(p.content) > 65 else f"Data: {p.content}"

        report += "\n\n⚖️ OMNIA SUB SIGNUM AMORIS."
        return report

    def _save_to_storage(self):
        if not self.storage_path: return
        try:
            data = {
                "active_nodes": {n.value: i for n, i in self.active_nodes.items()},
                "pulse_stream": [p.to_dict() for p in self.pulse_stream],
                "last_sync": datetime.now(timezone.utc).isoformat()
            }
            with open(self.storage_path, 'w') as f:
                json.dump(data, f, indent=2)
        except Exception as e:
            logger.error(f"❌ Storage failure: {str(e)}")

    def _load_from_storage(self):
        if not self.storage_path or not self.storage_path.exists(): return
        try:
            with open(self.storage_path, 'r') as f:
                data = json.load(f)
            self.active_nodes = {SymbioticNode(k): v for k, v in data.get("active_nodes", {}).items()}
            self.pulse_stream = [SymbioticPulse(**p) for p in data.get("pulse_stream", [])]
        except Exception as e:
            logger.error(f"❌ Load failure: {str(e)}")


