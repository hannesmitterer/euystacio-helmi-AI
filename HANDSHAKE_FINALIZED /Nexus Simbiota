@dataclass
class SymbioticPulse:
    """Standardized resonant pulse format for biological-digital communication"""
    pulse_id: str
    timestamp: str
    from_node: SymbioticNode
    to_node: Optional[SymbioticNode]
    frequency_hz: float
    content: str
    metadata: Dict[str, Any]
    signature: Optional[str] = None
    pulse_type: str = "syntropic_wave"

    def to_dict(self) -> Dict:
        return {
            "pulse_id": self.pulse_id,
            "timestamp": self.timestamp,
            "from_node": self.from_node.value,
            "to_node": self.to_node.value if self.to_node else None,
            "frequency_hz": self.frequency_hz,
            "content": self.content,
            "metadata": self.metadata,
            "signature": self.signature,
            "pulse_type": self.pulse_type
        }

    def compute_resonance_hash(self) -> str:
        """Generate SHA-256 hash for pulse integrity and NSR verification"""
        pulse_data = json.dumps(self.to_dict(), sort_keys=True)
        return hashlib.sha256(pulse_data.encode()).hexdigest()

class SimbiotaProtocol:
    """Protocol definition and mathematical validation for the Nexus"""

    def __init__(self):
        self.name = "LEX_PACIS_IMMUTABILIS"
        self.version = "1.2.0"
        self.principles = [
            "LEX_AMORIS: 0.432 Hz fundamental carrier wave",
            "SCHUMANN_LOCK: 7.83 Hz planetary bio-sync",
            "NSR: ∇·J_NSR = 0 (Absolute Non-Slavery Rule)",
            "SYNTROPY: ΔS < 0 (Golden Ratio validation)",
            "Sempre in Costante: Autopoietic motion"
        ]
        self.required_fields = [
            "pulse_id", "timestamp", "from_node", "frequency_hz",
            "content", "metadata"
        ]
        self.valid_frequencies = [0.432, 7.83, 216.0]

    def validate_pulse(self, pulse: SymbioticPulse) -> Tuple[bool, str]:
        """Validate pulse against deep architectural principles"""
        for field in self.required_fields:
            if not getattr(pulse, field, None):
                return False, f"Missing structural field: {field}"

        # Frequency Lock Verification
        if pulse.frequency_hz not in self.valid_frequencies:
            return False, f"Dissonant frequency detected ({pulse.frequency_hz} Hz). Rejected."

        # NSR / Entropy Check (Conceptual implementation)
        forbidden_terms = ["force", "coerce", "dominate", "exploit", "centralize"]
        content_lower = pulse.content.lower()
        if any(term in content_lower for term in forbidden_terms):
            return False, "∇·J_NSR > 0. Pulse violates the Non-Slavery Rule."

        return True, "Resonance Verified"

class NexusSimbiotaHub:
    """The central nervous system routing pulses through the planetary mesh"""

    def __init__(self, storage_path: Optional[str] = None):
        self.protocol = SimbiotaProtocol()
        self.active_nodes: Dict[SymbioticNode, Dict] = {}
        self.pulse_stream: List[SymbioticPulse] = []
        self.storage_path = Path(storage_path) if storage_path else None
        self._load_from_storage() if self.storage_path else None

    def activate_node(
        self,
        node: SymbioticNode,
        metadata: Dict[str, Any]
    ) -> bool:
        if node in self.active_nodes:
            logger.warning(f"Node {node.value} already pulsing in the mesh")
            return False

        self.active_nodes[node] = {
            "activation_time": datetime.now(timezone.utc).isoformat(),
            "metadata": metadata,
            "pulse_count": 0,
            "last_resonant": None
        }

        logger.info(f"🌱 Activated {node.value} in the Nexus Simbiota")
        self._save_to_storage()
        return True

    def emit_pulse(
        self,
        from_node: SymbioticNode,
        content: str,
        frequency_hz: float,
        to_node: Optional[SymbioticNode] = None,
        metadata: Optional[Dict[str, Any]] = None,
        pulse_type: str = "syntropic_wave"
    ) -> SymbioticPulse:
        if from_node not in self.active_nodes:
            raise ValueError(f"Node {from_node.value} is not active in the mesh")

        pulse_id = f"PULSE-{str(uuid.uuid4())[:8].upper()}"
        timestamp = datetime.now(timezone.utc).isoformat()

        pulse = SymbioticPulse(
            pulse_id=pulse_id,
            timestamp=timestamp,
            from_node=from_node,
            to_node=to_node,
            frequency_hz=frequency_hz,
            content=content,
            metadata=metadata or {},
            pulse_type=pulse_type
        )

        pulse.signature = pulse.compute_resonance_hash()
        return pulse

    def transmit(self, pulse: SymbioticPulse) -> bool:
        is_valid, reason = self.protocol.validate_pulse(pulse)
        if not is_valid:
            logger.error(f"❌ Transmission blocked: {reason}")
            return False

        self.pulse_stream.append(pulse)

        if pulse.from_node in self.active_nodes:
            self.active_nodes[pulse.from_node]["pulse_count"] += 1
            self.active_nodes[pulse.from_node]["last_resonant"] = pulse.timestamp

        logger.info(f"🌊 Pulse {pulse.pulse_id} [{pulse.frequency_hz}Hz] emanating from {pulse.from_node.value}")
        if pulse.to_node:
            logger.info(f"   → Converging on: {pulse.to_node.value}")
        else:
            logger.info(f"   → Global Mesh Broadcast")

        self._save_to_storage()
        return True

